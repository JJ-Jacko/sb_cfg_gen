{
    "log": {
        "level": "info"
    },
    "dns": {
        "servers": [
            {
                "tag": "dns_proxy",
                "type": "tcp",
                "server": "1.1.1.1",
                "detour": "🚀 Proxy",
                "domain_resolver": "dns_resolver"
            },
            {
                "tag": "dns_direct",
                "type": "https",
                "server": "dns.alidns.com",
                "domain_resolver": "dns_resolver"
            },
            {
                "tag": "dns_resolver",
                "type": "udp",
                "server": "223.5.5.5"
            },
            {
                "tag": "dns_fakeip",
                "type": "fakeip",
                "inet4_range": "198.18.0.0/15",
                "inet6_range": "fc00::/18"
            }
        ],
        "rules": [
            {
                "rule_set": "geosite-geolocation-!cn",
                "query_type": [
                    "A",
                    "AAAA"
                ],
                "server": "dns_fakeip"
            },
            {
                "rule_set": "geosite-geolocation-!cn",
                "query_type": "CNAME",
                "server": "dns_proxy"
            },
            {
                "query_type": [
                    "A",
                    "AAAA",
                    "CNAME"
                ],
                "invert": true,
                "action": "predefined",
                "rcode": "REFUSED"
            }
        ],
        "final": "dns_direct",
        "independent_cache": true
    },
    "ntp": {
        "enabled": true,
        "server": "time.apple.com",
        "server_port": 123,
        "interval": "30m"
    },
    "inbounds": [
        {
            "tag": "mixed-in",
            "type": "mixed",
            "listen": "0.0.0.0",
            "listen_port": 2080
        },
        {
            "tag": "tun-in",
            "type": "tun",
            "address": "172.19.0.1/30",
            "auto_route": true,
            "strict_route": true,
            "stack": "mixed",
            "sniff": true
        }
    ],
    "outbounds": [
        {
            "tag": "🚫 Reject",
            "type": "block"
        },
        {
            "tag": "⚡ Direct",
            "type": "direct"
        }
    ],
    "route": {
        "default_domain_resolver": "dns_resolver",
        "rule_set": [],
        "rules": [
            {
                "action": "sniff"
            },
            {
                "protocol": "dns",
                "action": "hijack-dns"
            },
            {
                "clash_mode": "Global",
                "outbound": "🚀 Proxy"
            }
        ],
        "auto_detect_interface": true,
        "final": "🚀 Proxy"
    },
    "experimental": {
        "cache_file": {
            "enabled": true,
            "store_fakeip": true
        }
    }
}