{
    "log": {
        "level": "info"
    },
    "experimental": {
        "cache_file": {
            "enabled": true,
            "store_fakeip": true
        }
    },
    "inbounds": [
        {
            "tag": "mixed-in",
            "type": "mixed",
            "listen": "0.0.0.0",
            "listen_port": 8848
        },
        {
            "tag": "tun-in",
            "type": "tun",
            "address": "172.19.0.1/30",
            "auto_route": true,
            "strict_route": true,
            "stack": "mixed"
        }
    ],
    "outbounds": [
        {
            "tag": "🚫 Reject",
            "type": "block"
        },
        {
            "tag": "⚡ Direct",
            "type": "direct"
        }
    ],
    "route": {
        "default_domain_resolver": "Ali-DNS",
        "rule_set": [
            {
                "tag": "GeoSite-Private",
                "type": "remote",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/private.srs",
                "format": "binary"
            },
            {
                "tag": "GeoIP-Private",
                "type": "remote",
                "format": "binary",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/private.srs"
            },
            {
                "tag": "GeoSite-CN",
                "type": "remote",
                "format": "binary",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cn.srs"
            },
            {
                "tag": "GeoIP-CN",
                "type": "remote",
                "format": "binary",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs"
            },
            {
                "tag": "GeoLocation-!CN",
                "type": "remote",
                "format": "binary",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/geolocation-!cn.srs"
            },
            {
                "tag": "GeoSite-Spotify",
                "type": "remote",
                "format": "binary",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/spotify.srs"
            },
            {
                "tag": "GeoSite-Linkedin",
                "type": "remote",
                "format": "binary",
                "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/linkedin.srs"
            }
        ],
        "rules": [
            {
                "action": "sniff",
                "inbound": [
                    "mixed-in",
                    "tun-in"
                ]
            },
            {
                "protocol": "dns",
                "action": "hijack-dns"
            },
            {
                "clash_mode": "Global",
                "outbound": "🚀 Proxy"
            },
            {
                "domain": "services.googleapis.cn",
                "rule_set": "GeoSite-Linkedin",
                "outbound": "🚀 Proxy"
            },
            {
                "rule_set": [
                    "GeoIP-Private",
                    "GeoSite-Private",
                    "GeoIP-CN",
                    "GeoSite-CN",
                    "GeoSite-Spotify"
                ],
                "outbound": "⚡ Direct"
            }
        ],
        "auto_detect_interface": true,
        "final": "🚀 Proxy"
    },
    "dns": {
        "servers": [
            {
                "tag": "Ali-DNS",
                "type": "https",
                "server": "223.5.5.5",
                "server_port": 443,
                "path": "/dns-query",
                "domain_resolver": "Ali-DNS-UDP"
            },
            {
                "tag": "Ali-DNS-UDP",
                "type": "udp",
                "server": "223.5.5.5",
                "server_port": 53
            },
            {
                "tag": "Cloudflare-DNS",
                "type": "tls",
                "server": "1.1.1.1",
                "domain_resolver": "Cloudflare-DNS-UDP",
                "detour": "🚀 Proxy"
            },
            {
                "tag": "Cloudflare-DNS-UDP",
                "type": "udp",
                "server": "1.1.1.1",
                "detour": "🚀 Proxy"
            }
        ],
        "rules": [
            {
                "action": "route",
                "clash_mode": "Global",
                "server": "Cloudflare-DNS"
            },
            {
                "action": "route",
                "rule_set": [
                    "GeoSite-CN",
                    "GeoIP-CN",
                    "GeoSite-Private",
                    "GeoIP-Private",
                    "GeoSite-Spotify"
                ],
                "server": "Ali-DNS"
            },
            {
                "action": "route",
                "rule_set": [
                    "GeoLocation-!CN",
                    "GeoSite-Linkedin"
                ],
                "server": "Cloudflare-DNS"
            }
        ],
        "final": "Cloudflare-DNS",
        "independent_cache": true
    }
}